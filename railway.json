{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm build:frontend"
  },
  "deploy": {
    "startCommand": "node_modules/.bin/pm2-runtime start production.config.js --env production",
    "restartPolicyType": "ON_FAILURE"
  }
}
